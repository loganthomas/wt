#!/bin/sh
# Pre-commit gate: the same checks CI runs, caught before the push.
# Enable once per clone:  git config core.hooksPath .githooks
# Bypass one commit:      git commit --no-verify

set -u

# Must match .github/workflows/lint.yml.
GOLANGCI_LINT="github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.12.2"

if [ -t 2 ] && [ -z "${NO_COLOR:-}" ]; then
	green='\033[32m'
	red='\033[31m'
	reset='\033[0m'
else
	green=''
	red=''
	reset=''
fi

fail=0

run_check() {
	label=$1
	shift
	printf '  %-10s' "$label" >&2
	if out=$("$@" 2>&1); then
		printf "${green}[ok]${reset}\n" >&2
	else
		printf "${red}[FAIL]${reset}\n%s\n" "$out" >&2
		fail=1
	fi
}

printf 'wt pre-commit\n' >&2
run_check build go build ./...
run_check vet go vet ./...
run_check test go test -race ./...
run_check lint env CGO_ENABLED=0 go run "$GOLANGCI_LINT" run

exit "$fail"
