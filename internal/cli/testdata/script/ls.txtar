# wt ls lists every worktree: branch, path, state.
# Data goes to stdout only; nothing may leak to stderr (D13).

[!exec:git] skip 'git not on PATH'

exec git init -q -b main repo
cd repo
exec git commit -q --allow-empty -m 'initial'
exec git worktree add -q ../trees/login -b feature/login

exec wt ls
stdout 'main\s+.*[/\\]repo$'
stdout 'feature/login\s+.*[/\\]login$'
! stderr .

# a detached worktree is labeled, not blank
exec git worktree add -q --detach ../trees/scratch
exec wt ls
stdout '\(detached\)\s+.*[/\\]scratch'

# --porcelain: stable tab-separated fields, '-' for an empty state,
# so field count never varies for awk/cut consumers
exec wt ls --porcelain
stdout '^main\t.*[/\\]repo\t-$'
stdout '^feature/login\t.*[/\\]login\t-$'
stdout '^\(detached\)\t.*[/\\]scratch\t-$'
! stderr .

# outside any repository: exit 4 (D13), explanation on stderr only
mkdir $WORK/elsewhere
cd $WORK/elsewhere
exitcode 4 wt ls
stderr 'not inside a git repository'
! stdout .
