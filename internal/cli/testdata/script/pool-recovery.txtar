# Broken pool states must always have a way out (D15, R3):
# wedged lease records clear via release, half-provisioned slots
# reprovision themselves, and a guard-blocked slot never takes
# the whole pool down.

[!exec:git] skip 'git not on PATH'

exec git init -q -b main acme
cd acme
exec git commit -q --allow-empty -m 'initial'
exec wt init --yes --pool-size 1
stderr 'provisioned pool-1'

# a claim/done cycle guarantees the state tree for this repo exists
exec wt new feat-a
exec wt done feat-a

# corrupt the lease record by hand, as a crash or fs fault might
# (the glob covers only the existing slug segment; the lease dir
# itself is being invented here)
exec sh -c 'd="$(echo "$XDG_STATE_HOME"/wt/repos/*)" && mkdir -p "$d/leases/pool-1" && printf "not = [toml" > "$d/leases/pool-1/lease.toml"'

# the pool is wedged: claim must not steal what it cannot prove dead
exitcode 3 wt claim feat-b
stderr 'no free slot'
exec wt pool ls
stdout 'pool-1\s+claimed\s+\?\s+lease record unreadable'

# the escape hatch: release frees the slot anyway
exec wt release pool-1
stderr 'released pool-1'
exec wt claim feat-b
stdout '[/\\]pool-1$'

# a provision killed between worktree-add and warm leaves a
# registered but never-set-up slot; the next claim must redo the
# provision, not silently skip the setup hook forever
exec wt release feat-b
cp $WORK/hooked.toml .git/wt.toml
exec sh -c 'd="$(echo "$XDG_STATE_HOME"/wt/repos/*)" && rm -rf "$d/trees/pool-1" && rm -rf "$d/leases/pool-1"'
exec wt claim feat-c
stderr 'reprovisioning pool-1'
stderr 'running setup hook'
exists ../acme.trees/pool-1/setup-ran

# the hook artifact is not gitignored in this fixture, so the
# dirty guard still speaks for it on the way out
rm ../acme.trees/pool-1/setup-ran
exec wt done feat-c

# a slot the guards refuse must not take the whole pool down:
# the claim notes it, skips it, and uses the next slot
exec wt pool resize 2
stderr 'provisioned pool-2'
exec wt claim feat-d
stdout '[/\\]pool-1$'

# strand an orphan commit in pool-1 and drop its lease by hand,
# as a crashed session plus a reboot (PID reuse) would
exec git -C ../acme.trees/pool-1 checkout -q --detach
exec git -C ../acme.trees/pool-1 commit -q --allow-empty -m 'stranded'
exec sh -c 'd="$(echo "$XDG_STATE_HOME"/wt/repos/*)" && rm -rf "$d/leases/pool-1"'

exec wt claim feat-e
stdout '[/\\]pool-2$'
stderr 'skipping pool-1'
stderr 'reachable only from its detached HEAD'

# when nothing else is left, the claim surfaces the blockers
exitcode 3 wt claim feat-f
stderr 'blocked'

-- hooked.toml --
base = 'main'
trees_dir = '../acme.trees'

[hooks]
setup = 'touch setup-ran'

[pool]
size = 1
